# 复制本文件为 .env.local，并填入你的 Anthropic API key
# 申请地址：https://console.anthropic.com/

# 【项目专属配置】优先级最高，不会与终端 Claude Code 配置冲突
# 必填：Claude API 认证令牌
# API 使用：下面两种方法2选1：
PROJECT_ANTHROPIC_API_KEY=sk-ant-...
# PROJECT_ANTHROPIC_AUTH_TOKEN=你的令牌

# 可选：自定义 API 端点
# 如果使用官方 API，请注释掉或删除此行
PROJECT_ANTHROPIC_BASE_URL=xxxx

# 可选：指定模型名称（如果您的 token 对某些模型有限制，可以在这里配置）
# 不配置则使用默认值，代理 API 可能会自动选择可用模型
PROJECT_ANTHROPIC_MODEL=claude-sonnet-4-6
PROJECT_ANTHROPIC_FAST_MODEL=claude-sonnet-4-6

# 可选：本地笔记库路径（笔记会挂到对应 topic 旁边、面试历史默认导出到这里）
# 默认 ~/Documents/knowlege_library
KNOWLEDGE_LIBRARY_PATH=/Users/your-name/Documents/notes

# 可选：数据存储目录（题库、简历、学习进度等个人数据）
# 默认：~/Documents/ai-infra-tutor-data
# 建议：设置到独立目录，方便备份和多设备同步（如 iCloud/Dropbox）
DATA_DIR=~/Documents/ai-infra-tutor-data
DATA_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/ai-infra-tutor-data

