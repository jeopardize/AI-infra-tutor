# 复制本文件为 .env.local，并填入你的 Anthropic API key
# 申请地址：https://console.anthropic.com/

# 必填：Claude API 认证令牌
# 官方 API 使用：ANTHROPIC_API_KEY=sk-ant-...
# 自定义端点使用：ANTHROPIC_AUTH_TOKEN=你的令牌
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=粘贴为Claude Code专用分组令牌key

# 可选：自定义 API 端点
# 如果使用官方 API，请注释掉或删除此行
ANTHROPIC_BASE_URL=xxxx

# 可选：本地笔记库路径（笔记会挂到对应 topic 旁边、面试历史默认导出到这里）
# 默认 ~/Documents/knowlege_library
KNOWLEDGE_LIBRARY_PATH=/Users/your-name/Documents/notes
